class CodingStyleDocker:
    SOCKET_PATH = "/var/run/docker.sock"
    IMAGE_NAME = "banana-coding-style-checker"
    
    def __init__(self, REPORTS_DIR: str, DELIVERY_DIR: str) -> None:
        self.HAS_SOCKET_ACCESS = os.access(self.SOCKET_PATH, os.R_OK)
        
        self.DOCKER_EXEC_CMD = "docker"
        self.REPORTS_DIR = REPORTS_DIR
        self.DELIVERY_DIR = DELIVERY_DIR
        self.EXPORT_FILE = os.path.join(REPORTS_DIR, "coding-style-reports.log")
    
    def purge_image(self) -> None:
        if not self.HAS_SOCKET_ACCESS:
            self.DOCKER_EXEC_CMD = f"sudo {self.DOCKER_EXEC_CMD}"
            
        subprocess.run(
            [self.DOCKER_EXEC_CMD, "image", "rm", "-f", self.IMAGE_NAME],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
        )

    def build_image(self) -> None:
        print(f"{ColorsTTY.BLUE}Downloading source code...{ColorsTTY.RESET}")
        build_dir = "/tmp/banana_build"
        
        if os.path.exists(build_dir):
            subprocess.run(f"rm -rf {build_dir}", shell=True)
            
        subprocess.run(
            f"git clone git@github.com:Epitech/banana-coding-style-checker.git {build_dir}", 
            shell=True, check=True
        )
        
        print(f"{ColorsTTY.BLUE}Building Docker image...{ColorsTTY.RESET}")

        build_env = os.environ.copy()
        build_env["DOCKER_BUILDKIT"] = "1"
        
        try:
             subprocess.run(
                [self.DOCKER_EXEC_CMD, "build", "-t", self.IMAGE_NAME, "."],
                cwd=build_dir,
                env=build_env,
                check=True
            )
        finally:
            subprocess.run(f"rm -rf {build_dir}", shell=True)
        
        print(f"{ColorsTTY.GREEN}Image created successfully.{ColorsTTY.RESET}")

    def run(self) -> str:
        if os.path.exists(self.EXPORT_FILE):
            os.remove(self.EXPORT_FILE)
        
        if not self.HAS_SOCKET_ACCESS:
            self.DOCKER_EXEC_CMD = f"sudo {self.DOCKER_EXEC_CMD}"
        
        # Check if image exists
        image_check = subprocess.run(
            [self.DOCKER_EXEC_CMD, "image", "inspect", self.IMAGE_NAME],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
        )
        
        if image_check.returncode != 0:
            self.build_image()
        
        # Determine files to scan
        git_dir = os.path.join(self.DELIVERY_DIR, ".git")
        has_git = os.path.isdir(git_dir) and shutil.which("git") is not None
        
        scan_command = ""
        
        if has_git:
            # Use git ls-files to respect .gitignore
            # Generate the file list on host and pass it to docker via REPORTS_DIR (mounted at /mnt/reports)
            file_list_path = os.path.join(self.REPORTS_DIR, "kiwi_files.txt")
            
            # git ls-files -c -o --exclude-standard -z '*.c' '*.h' 'Makefile'
            # Note: We run this in DELIVERY_DIR
            with open(file_list_path, "wb") as f:
                subprocess.run(
                    ["git", "ls-files", "-c", "-o", "--exclude-standard", "-z", "*.c", "*.h", "Makefile"],
                    cwd=self.DELIVERY_DIR,
                    stdout=f,
                    stderr=subprocess.DEVNULL
                )
            
            scan_command = (
                'xargs -0 epiclang -fsyntax-only -fdiagnostics-format=sarif < /mnt/reports/kiwi_files.txt'
            )
        else:
             # Fallback to find
            scan_command = (
                'find . -type f \\( -name "*.c" -o -name "*.h" -o -name "Makefile" \\) '
                '-not -path "*/tests/*" '
                '-not -path "*/.git/*" -print0 | '
                'xargs -0 epiclang -fsyntax-only -fdiagnostics-format=sarif'
            )

        with open(self.EXPORT_FILE, "w") as f:
            subprocess.run([
                self.DOCKER_EXEC_CMD,
                "run",
                "--rm",
                "--security-opt", "label:disable",
                "-v", f"{self.DELIVERY_DIR}:/mnt/delivery:z",
                "-v", f"{self.REPORTS_DIR}:/mnt/reports:z",
                "-w", "/mnt/delivery",
                self.IMAGE_NAME,
                "bash", "-c", scan_command
            ], stdout=f, stderr=subprocess.STDOUT)
            
        # Cleanup temporary file if it exists
        if has_git and os.path.exists(os.path.join(self.REPORTS_DIR, "kiwi_files.txt")):
             os.remove(os.path.join(self.REPORTS_DIR, "kiwi_files.txt"))
        
        if not os.path.isfile(self.EXPORT_FILE) or os.path.getsize(self.EXPORT_FILE) == 0:
            pass # Parser handles empty/fallback
        
        return self.EXPORT_FILE

class Kiwi:
    
    def __init__(self) -> None:
        self.options: tuple[callable, int] = {
            "-c": (self.mr_clean, 0),
            "--clean": (self.mr_clean, 0),
            "-p": (self.change_path, 1),
            "--path": (self.change_path, 1),
            "--pull": (self.pull_image, 0)
        }
        
        self.codingStyle: CodingStyleDocker
        self.errors: list[CodingStyleError] = []
        self.reports_dir: str = None
        self.delivery_dir: str = None
        
        self.SUMMARY = {
            "FATAL": 0,
            "MAJOR": 0,
            "MINOR": 0,
            "INFO": 0
        }
        self.force_pull = False
    
    def interpret_options(self, options: list[str]) -> None:
        if "-h" in options or "--help" in options:
            self.show_help()
            exit(0)
        
        self.reports_dir = os.path.abspath('.')
        self.delivery_dir = os.path.abspath('.')
        
        if not os.path.isdir(self.delivery_dir):
            print(f"{ColorsTTY.RED}{self.delivery_dir} is not a directory{ColorsTTY.RESET}", file=sys.stderr)
            exit(1)
        
        options = options[1:]
        while options:
            option = options.pop(0)
            if option not in self.options:
                print(f"{ColorsTTY.RED}Unknown option {option}{ColorsTTY.RESET}", file=sys.stderr)
                exit(1)

            func, args = self.options[option]
            if args > 0:
                if len(options) < args:
                    print(f"{ColorsTTY.RED}Option {option} requires {args} argument(s){ColorsTTY.RESET}", file=sys.stderr)
                    exit(1)
                func(*options[:args])
                options = options[args:]
            else:
                func()

    def mr_clean(self) -> None:
        os.system(
            "find {delivery} ".format(delivery=self.delivery_dir) +
            " -o ".join([
                f"-name '{elem}' -delete" for elem in [
                    '#*#',
                    '*~',
                    '*.o',
                    '*.hi',
                    '*.a',
                    '*.so',
                    '*.gcno',
                    '*.gcda',
                    '*.gcov'
                ]
            ])
        )

    def parse_output(self, output: list[str]) -> None:
        git_exists = not os.system("command -v git > /dev/null 2>&1") and os.path.isdir(".git")

        for line in output:
            line = line.strip()
            if not line:
                continue
            
            # Try to parse line as valid JSON (SARIF)
            try:
                sarif_data = json.loads(line)
            except json.JSONDecodeError:
                continue

            # Process SARIF data
            for run in sarif_data.get("runs", []):
                for result in run.get("results", []):
                    # Parse message: [Banana] [Type] Message (Code)
                    message = result.get("message", {}).get("text", "")
                    match = re.search(r"\[Banana\] \[(.*?)\] (.*) \((.*)\)", message)
                    
                    if not match:
                        continue
                        
                    error_type = match.group(1).upper()
                    error_desc = match.group(2)
                    error_code = match.group(3)
                    
                    # Locations
                    for location in result.get("locations", []):
                        physical_loc = location.get("physicalLocation", {})
                        artifact_loc = physical_loc.get("artifactLocation", {})
                        region = physical_loc.get("region", {})
                        
                        uri = artifact_loc.get("uri", "")
                        if uri.startswith("file://"):
                            uri = uri[7:]
                        
                        if uri.startswith("/mnt/delivery"):
                            rel_path = os.path.relpath(uri, "/mnt/delivery")
                            file_path = os.path.join(self.delivery_dir, rel_path)
                        elif uri.startswith(self.delivery_dir):
                             file_path = uri
                        elif uri.startswith("file://" + self.delivery_dir):
                             file_path = uri[7:]
                        else:
                            file_path = uri

                        if git_exists and not os.system(f"git check-ignore -q '{file_path}' > /dev/null 2>&1"):
                            continue
                        
                        line_no = region.get("startLine", 0)
                        
                        self.errors.append(CodingStyleError(
                            file=file_path,
                            line=line_no,
                            error_type=error_type,
                            error=error_code
                        ))

    def show_help(self) -> None:
        print("Usage: kiwi [OPTIONS]\n")
        print("Options:")
        print("  -c, --clean\t\tRemove temporary files")
        print("  -p, --path <path>\tChange the path to the delivery directory")
        print("  --pull\t\tForce update the docker image")
        print("  -h, --help\t\tShow this help message")
    
    def change_path(self, path: str) -> None:
        if not os.path.isdir(path):
            print(f"{ColorsTTY.RED}{path} is not a directory{ColorsTTY.RESET}", file=sys.stderr)
            exit(1)
        
        self.delivery_dir = os.path.abspath(path)

    def pull_image(self) -> None:
        self.force_pull = True

    def run(self) -> None:
        self.interpret_options(sys.argv)
        self.codingStyle = CodingStyleDocker(self.reports_dir, self.delivery_dir)
        
        if self.force_pull:
            self.codingStyle.purge_image()

        export_file: str = self.codingStyle.run()
        with open(export_file) as f:
            lines = f.readlines()
        
        self.parse_output(lines)
        os.remove(export_file)
        
        for error in self.errors:
            print(KiwiUtils.FORMAT.format(
                type=KiwiUtils.TYPES[error.error_type],
                error_type=error.error_type,
                file=error.file,
                line=error.line,
                error=error.error,
                description=KiwiUtils.DESCRIPTIONS[error.error],
                bold=ColorsTTY.BOLD,
                reset=ColorsTTY.RESET,
                red=ColorsTTY.RED,
                yellow=ColorsTTY.YELLOW,
                green=ColorsTTY.GREEN,
                magenta=ColorsTTY.MAGENTA,
                cyan=ColorsTTY.CYAN,
                blue=ColorsTTY.BLUE
            ))
        
        for error in self.errors:
            self.SUMMARY[error.error_type] += 1
        
        if not any(self.SUMMARY.values()):
            KiwiArt.print()
            print(f"{ColorsTTY.BOLD}{ColorsTTY.GREEN}Good job! No coding style errors found.{ColorsTTY.RESET}")
            exit(0)
        
        print(KiwiUtils.FOOTER.format(
            bold=ColorsTTY.BOLD,
            reset=ColorsTTY.RESET,
            red=ColorsTTY.RED,
            yellow=ColorsTTY.YELLOW,
            green=ColorsTTY.GREEN,
            magenta=ColorsTTY.MAGENTA,
            cyan=ColorsTTY.CYAN,
            blue=ColorsTTY.BLUE,
            fatal=self.SUMMARY["FATAL"],
            major=self.SUMMARY["MAJOR"] + self.SUMMARY["FATAL"],
            minor=self.SUMMARY["MINOR"],
            info=self.SUMMARY["INFO"]
        ), end='')

if __name__ == "__main__":
    Kiwi().run()
